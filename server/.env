NODE_ENV=development
PORT=5000

# Local MongoDB (install MongoDB or change to your URI)
MONGODB_URI=mongodb://127.0.0.1:27017/talentforge-ai
USE_MEMORY_DB=false

# JWT
JWT_SECRET=TalentForgeAI_JWT_Secret_2026
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_MINUTES=10

# SMTP: leave empty for dev (emails will be skipped)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=TalentForge AI <no-reply@example.com>

# Client URL
CLIENT_URL=http://localhost:5173
